# Runtime mode
APP_ENV=paper
TRADING_MODE=paper
AWS_REGION=ap-southeast-2
KILL_SWITCH=false

# Optional AWS SSM settings overlay. Keep false for local development.
ENABLE_SSM_SETTINGS=false
SSM_PARAMETER_PREFIX=/agents-invest

# PRISM runtime loop
# auto = morning before noon Korea time, afternoon after noon. both runs both batches every loop.
PRISM_BATCH_MODE=auto
RUN_INTERVAL_SECONDS=3600
PRISM_BATCH_TIMEOUT_SECONDS=900

# Risk limits
MAX_DAILY_LOSS_PCT=3.0
MAX_POSITIONS=10
MAX_SAME_SECTOR=3
MAX_SECTOR_WEIGHT_PCT=30.0
MIN_CASH_WEIGHT_PCT=0.0

# Profit scoring thresholds
MIN_BUY_SCORE=7.0
MIN_PROFIT_SCORE=60.0
MIN_RISK_REWARD=1.2
MAX_EXPECTED_LOSS_PCT=7.0

# Paper validation thresholds
PAPER_MIN_TRADES=30
PAPER_MIN_WIN_RATE_PCT=45.0
PAPER_MIN_EXPECTANCY_PCT=0.5
PAPER_MAX_MDD_PCT=15.0
PAPER_MIN_PROFIT_FACTOR=1.2

# Logging and alerts
LOG_LEVEL=INFO
TELEGRAM_ENABLED=true
CLOUDWATCH_ENABLED=false

# Local-only Telegram values. Keep these blank in committed files.
# Run: python scripts/configure_telegram.py --target local
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Secret names. Store real values in AWS Secrets Manager or SSM Parameter Store.
OPENAI_API_KEY_SECRET_NAME=/agents-invest/openai/api-key
KIS_APP_KEY_SECRET_NAME=/agents-invest/kis/app-key
KIS_APP_SECRET_SECRET_NAME=/agents-invest/kis/app-secret
KIS_ACCOUNT_NO_SECRET_NAME=/agents-invest/kis/account-no
TELEGRAM_BOT_TOKEN_SECRET_NAME=/agents-invest/telegram/bot-token
TELEGRAM_CHAT_ID_SECRET_NAME=/agents-invest/telegram/chat-id
KILL_SWITCH_PARAMETER_NAME=/agents-invest/kill-switch