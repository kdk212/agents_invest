{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CreateAgentsInvestParameters",
      "Effect": "Allow",
      "Action": [
        "ssm:PutParameter",
        "ssm:AddTagsToResource"
      ],
      "Resource": "arn:aws:ssm:ap-southeast-2:*:parameter/agents-invest/*"
    },
    {
      "Sid": "EncryptSecureParameters",
      "Effect": "Allow",
      "Action": [
        "kms:Encrypt",
        "kms:GenerateDataKey"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "kms:ViaService": "ssm.ap-southeast-2.amazonaws.com"
        }
      }
    }
  ]
}
